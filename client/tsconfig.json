{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@lan-bomber/shared": ["../shared/src/index.ts"]
    },
    "resolveJsonModule": true
  },
  "include": ["src/renderer/**/*", "src/renderer/globals.d.ts", "scripts/**/*", "../shared/src/**/*"]
}
